{
  "manifest_version": 3,
  "name": "SkipClick - Job Radar",
  "version": "1.0.0",
  "description": "Instantly overlays visa sponsorship history and security clearance requirements onto LinkedIn job cards.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["company_db.json"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ]
}
